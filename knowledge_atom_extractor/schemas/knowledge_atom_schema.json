{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Knowledge Atom Schema",
  "description": "Schema for knowledge atoms extracted from research files",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^atom_[a-f0-9]{8}$",
      "description": "Unique identifier in atom_XXXXXXXX format"
    },
    "content": {
      "type": "string",
      "minLength": 10,
      "description": "The extracted knowledge content"
    },
    "type": {
      "type": "string",
      "enum": ["pattern", "anti-pattern", "principle", "finding"],
      "description": "Type of knowledge atom"
    },
    "category": {
      "type": "string",
      "minLength": 1,
      "description": "Research topic category"
    },
    "evidence_strength": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Evidence strength score (0.0-1.0)"
    },
    "specificity": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Specificity score (0.0-1.0)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Related keywords/tags"
    },
    "confidence": {
      "type": "string",
      "enum": ["HIGH", "MEDIUM", "LOW"],
      "description": "Confidence level"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "format": "uri",
            "description": "Source file path"
          },
          "lines": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            },
            "description": "Line numbers in source file"
          },
          "relevance": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Relevance score (0.0-1.0)"
          }
        },
        "required": ["file", "lines", "relevance"],
        "additionalProperties": false
      },
      "description": "Source file references"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "relationships": {
      "type": "object",
      "properties": {
        "upstream": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Upstream dependencies"
        },
        "downstream": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Downstream dependencies"
        },
        "category": {
          "type": "string",
          "enum": ["foundational", "critical", "useful", "exploratory"],
          "description": "Ranking category"
        }
      },
      "additionalProperties": false,
      "description": "Upstream/downstream dependencies"
    },
    "validation": {
      "type": "object",
      "properties": {
        "schema_compliant": {
          "type": "boolean",
          "description": "Schema compliance status"
        },
        "duplicate_check": {
          "type": "boolean",
          "description": "Duplicate check status"
        },
        "ranking_applied": {
          "type": "boolean",
          "description": "Ranking applied status"
        }
      },
      "required": ["schema_compliant", "duplicate_check", "ranking_applied"],
      "additionalProperties": false,
      "description": "Processing metadata"
    }
  },
  "required": ["id", "content", "type", "category", "evidence_strength", "specificity", "confidence", "sources", "timestamp", "validation"],
  "additionalProperties": false
